# Don't commit AI Digest files or DS_Store files
.aidigestignore
.DS_Store

# Don't commit certificates or extension builds
build/
cert/

# Don't commit sample data
examples/
cookie-sample.json

# Don't commit environment variables
.env
.env.local

# Don't commit the built manifest.json (since it has keys)
manifest.json

# Don't commit documentation drafts
docs/

# Dependencies
node_modules/

# WXT
.wxt/
.output/
